# Server Configuration
PORT=5000
NODE_ENV=development

# Database
# Local development (default)
MONGO_URI=mongodb://localhost:27017/resort-lease

# Production (MongoDB Atlas) - replace with your actual Atlas connection string
# MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/resort-lease?retryWrites=true&w=majority

# Authentication
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Optional: Cloudinary for file uploads (if used)
# CLOUDINARY_URL=cloudinary://<api-key>:<api-secret>@<cloud-name>
